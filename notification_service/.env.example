NODE_ENV=development
SERVICE_PORT=3000
LOG_LEVEL=info

KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=notification-service
KAFKA_TOPIC=bank.transactions
KAFKA_CLIENT_ID=notification-service-client

EMAIL_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=SecureBank <noreply@securebank.com>

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-token
VAULT_SECRET_PATH=secret/data/securebank

MAX_EMAILS_PER_USER_PER_HOUR=5
MAX_RETRIES=3
RETRY_DELAY_MS=1000
